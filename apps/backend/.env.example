# Database (Neon Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT secret — MUST match the frontend's secret if frontend verifies tokens locally
JWT_SECRET="change-me-to-a-strong-random-string"

# Origin allowed to call this API (the frontend Vercel URL)
# Use a comma-separated list for multiple origins
FRONTEND_ORIGIN="https://hrms.infinititechpartners.com,http://localhost:3000"

# Cron secret used by Vercel Cron to call /api/cron/*
CRON_SECRET="change-me"
