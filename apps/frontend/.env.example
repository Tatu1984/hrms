# Public — read by browser JS. Points at the backend Vercel project.
# Dev: http://localhost:3001
# Prod: https://hrms-backend.vercel.app (or your custom domain)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Server-only — used by middleware.ts to verify the session JWT without
# round-tripping to the backend. MUST match the backend's JWT_SECRET.
JWT_SECRET=change-me
