# JWT Secret - REQUIRED. Generate a strong random string (min 16 chars), e.g.
#   openssl rand -base64 48
# Never reuse this example value; set the real one in your host's env (Vercel).
JWT_SECRET=

# App URL - Change to your production domain
NEXT_PUBLIC_APP_URL="https://infinititechpartners.com"

# Database URL - Use PostgreSQL for production (Vercel Postgres or other provider)
# For local development: file:./dev.db
# For production: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="file:./dev.db"

# Optional: If using Vercel Postgres
# POSTGRES_URL=""
# POSTGRES_PRISMA_URL=""
# POSTGRES_URL_NON_POOLING=""

# Cron Job Secret for Auto-Heartbeat
CRON_SECRET=change-this-to-a-random-secret-key

# ==========================================
# AI/ML Configuration (R&D Branch)
# ==========================================

# NOTE: OPENAI_API_KEY is LEGACY and no longer read at runtime. The app uses the
# provider-agnostic AI_API_KEY / AI_BASE_URL / AI_MODEL trio at the bottom of
# this file. Leave AI vars empty to run with AI features gracefully disabled.

# AI Feature Flags (set to 'true' to enable)
AI_DOCUMENT_PROCESSING="true"
AI_PREDICTIVE_ANALYTICS="true"
AI_SMART_RECRUITMENT="true"
AI_CHATBOT="true"
AI_SENTIMENT_ANALYSIS="true"
AI_INTELLIGENT_AUTOMATION="true"
AI_LEARNING_DEVELOPMENT="true"
AI_ADVANCED_ANALYTICS="true"

# AES-256-GCM key (64 hex chars) for encrypting integration tokens at rest
ENCRYPTION_KEY=

# Vercel Blob storage (file uploads in production). Create a Blob store in Vercel.
BLOB_READ_WRITE_TOKEN=

# LLM provider (OpenAI-compatible). For free Groq: set AI_BASE_URL + AI_API_KEY + AI_MODEL.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# ==========================================
# Billing (Stripe) — OPTIONAL. Unset ⇒ billing disabled, app unaffected.
# Create products/prices + a webhook (event: checkout.session.completed,
# customer.subscription.updated/deleted) in the Stripe dashboard.
# ==========================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# ==========================================
# Email (Resend) — OPTIONAL. Unset ⇒ password-reset links are logged to the
# server console instead of emailed (fine for a single-admin deployment).
# ==========================================
RESEND_API_KEY=
EMAIL_FROM="HRMS <onboarding@resend.dev>"
